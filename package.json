{
  "name": "purela-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/tailwind.css -o ./public/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/tailwind.css -o ./public/tailwind.css --watch",
    "prebuild": "npm run build:css",
    "predev": "npm run build:css",
    "build": "nuxt build",
    "dev": "concurrently -k -n nuxt,css -c blue,magenta \"nuxt dev\" \"npm run watch:css\"",
    "dev:nuxt": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxtjs/supabase": "^1.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "echarts": "^5.5.0",
    "nuxt": "^3.15.4",
    "nuxt-auth-utils": "^0.5.0",
    "papaparse": "^5.4.1",
    "rolldown": "^1.0.0",
    "vue": "^3.5.0",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/icon": "^1.13.0",
    "@nuxtjs/i18n": "^9.5.6",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/papaparse": "^5.3.15",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.0"
  }
}
