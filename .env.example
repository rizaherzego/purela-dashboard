# --- Supabase ---
# Public URL and anon key (safe to expose to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key

# Service-role key — SERVER ONLY. Bypasses RLS. Used by Nuxt server routes
# for upload, ETL, and reads from internal views. Never ship this to the client.
NUXT_SUPABASE_SERVICE_KEY=your-service-role-key

# --- Auth ---
# Shared password for the dashboard. Change this for each environment.
NUXT_DASHBOARD_PASSWORD=change-me

# Random 32+ char secret used by nuxt-auth-utils to sign session cookies.
# Generate with: openssl rand -base64 48
NUXT_SESSION_PASSWORD=please-replace-this-with-at-least-32-random-chars
