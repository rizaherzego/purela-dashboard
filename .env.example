# --- Supabase ---
# Read by @nuxtjs/supabase. URL and anon key are fine to expose to the browser;
# service key is server-only (used via serverSupabaseServiceRole(event)).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Auth ---
# Shared password for the dashboard. Change this per environment.
NUXT_DASHBOARD_PASSWORD=change-me

# Random 32+ char secret used by nuxt-auth-utils to sign session cookies.
# Generate with: openssl rand -base64 48
NUXT_SESSION_PASSWORD=please-replace-this-with-at-least-32-random-chars
